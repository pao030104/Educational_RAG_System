rag_qa/core/bert_query_classifier/*.json
rag_qa/core/bert_query_classifier/*.safetensors
rag_qa/core/bert_query_classifier/vocab.txt
rag_qa/core/bert_query_classifier/special_tokens_map.json
rag_qa/core/bert_query_classifier/tokenizer_config.json

# 模型训练临时目录
rag_qa/core/bert_results/
rag_qa/core/bert_logs/
rag_qa/core/bert_eval_tmp/

